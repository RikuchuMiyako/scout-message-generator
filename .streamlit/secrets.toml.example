# Streamlit Community Cloud の Settings → Secrets にこの内容を貼り付けてください。
# ローカルで使う場合は、このファイルを .streamlit/secrets.toml にコピーして値を設定します
# （.streamlit/secrets.toml は .gitignore 済みでコミットされません）。

# Anthropic Claude API キー
ANTHROPIC_API_KEY = "sk-ant-..."

# 簡易ログイン用の共有パスワード（未設定の場合は認証画面をスキップします）
APP_PASSWORD = "ここに共有パスワード"
